---
import { profile } from '../data/profile';

const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)]">
  <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-4 px-6 py-8 sm:flex-row">
    <p class="text-sm text-[var(--color-text-muted)]">
      &copy; {year} {profile.name}. Built with
      <a href="https://astro.build" class="text-[var(--color-accent)] hover:underline" target="_blank" rel="noopener">Astro</a>.
    </p>
    <div class="flex items-center gap-4">
      <a
        href={profile.social.github}
        class="text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-accent)]"
        target="_blank"
        rel="noopener"
      >
        GitHub
      </a>
      <a
        href="/rss.xml"
        class="text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-accent)]"
      >
        RSS
      </a>
    </div>
  </div>
</footer>