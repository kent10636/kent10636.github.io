---
import { profile } from '../data/profile';
---

<section class="relative mx-auto max-w-5xl px-6 pt-16 pb-8 sm:pt-24 sm:pb-12">
  <div class="animate-fade-in-up flex flex-col items-start gap-6 sm:flex-row sm:items-center sm:gap-8">
    <img
      src={profile.avatar}
      alt={profile.name}
      class="h-24 w-24 rounded-2xl border border-[var(--color-border)] shadow-lg sm:h-28 sm:w-28"
      width="112"
      height="112"
    />
    <div>
      <p class="mb-1 text-sm font-medium text-[var(--color-accent)]">{profile.title}</p>
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
        Hi, I'm {profile.name}
      </h1>
      <p class="mt-3 max-w-lg text-lg text-[var(--color-text-muted)]">
        {profile.tagline}
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a
          href={profile.social.github}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-lg bg-[var(--color-accent)] px-4 py-2 text-sm font-medium text-white transition-opacity hover:opacity-90"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
        <a
          href="/about"
          class="inline-flex items-center gap-2 rounded-lg border border-[var(--color-border)] px-4 py-2 text-sm font-medium text-[var(--color-text)] transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
        >
          About me
        </a>
      </div>
    </div>
  </div>
</section>