---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog" description="Thoughts on software, projects, and the web.">
  <section class="mx-auto max-w-3xl px-6 py-16 sm:py-20">
    <h1 class="mb-2 text-4xl font-bold tracking-tight">Blog</h1>
    <p class="mb-10 text-lg text-[var(--color-text-muted)]">
      {posts.length} post{posts.length === 1 ? '' : 's'} and counting.
    </p>
    <div class="space-y-4">
      {posts.map((post) => <BlogCard post={post} />)}
    </div>
  </section>
</BaseLayout>