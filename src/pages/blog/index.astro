---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { site } from '../../data/site';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={site.blog.title} description="技术笔记、项目记录与随想。">
  <section class="mx-auto max-w-3xl px-6 py-16 sm:py-20">
    <h1 class="mb-2 text-4xl font-bold tracking-tight">{site.blog.title}</h1>
    <p class="mb-10 text-lg text-[var(--color-text-muted)]">
      {site.blog.posts(posts.length)}
    </p>
    <div class="space-y-4">
      {posts.map((post) => <BlogCard post={post} />)}
    </div>
  </section>
</BaseLayout>