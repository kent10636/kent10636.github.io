---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile } from '../data/profile';
---

<BaseLayout title="About" description={profile.bio}>
  <section class="mx-auto max-w-3xl px-6 py-16 sm:py-20">
    <div class="animate-fade-in-up">
      <img
        src={profile.avatar}
        alt={profile.name}
        class="mb-8 h-28 w-28 rounded-2xl border border-[var(--color-border)] shadow-lg"
        width="112"
        height="112"
      />
      <h1 class="text-4xl font-bold tracking-tight">About</h1>
      <p class="mt-4 text-lg leading-relaxed text-[var(--color-text-muted)]">{profile.bio}</p>

      <h2 class="mt-12 mb-6 text-2xl font-bold">Timeline</h2>
      <div class="space-y-6">
        {profile.timeline.map((item) => (
          <div class="flex gap-4">
            <span class="w-14 shrink-0 text-sm font-bold text-[var(--color-accent)]">{item.year}</span>
            <div>
              <h3 class="font-semibold">{item.title}</h3>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">{item.description}</p>
            </div>
          </div>
        ))}
      </div>

      <h2 class="mt-12 mb-4 text-2xl font-bold">Connect</h2>
      <div class="flex flex-wrap gap-4">
        <a
          href={profile.social.github}
          target="_blank"
          rel="noopener"
          class="text-[var(--color-accent)] hover:underline"
        >
          GitHub
        </a>
        {profile.email && (
          <a href={`mailto:${profile.email}`} class="text-[var(--color-accent)] hover:underline">
            Email
          </a>
        )}
      </div>
    </div>
  </section>
</BaseLayout>