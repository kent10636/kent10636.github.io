---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404" description="Page not found.">
  <section class="mx-auto flex max-w-3xl flex-col items-center px-6 py-32 text-center">
    <p class="text-8xl font-bold text-[var(--color-accent)]">404</p>
    <h1 class="mt-4 text-2xl font-bold">Page not found</h1>
    <p class="mt-2 text-[var(--color-text-muted)]">The page you're looking for doesn't exist.</p>
    <a
      href="/"
      class="mt-8 rounded-lg bg-[var(--color-accent)] px-5 py-2.5 text-sm font-medium text-white hover:opacity-90"
    >
      Back home
    </a>
  </section>
</BaseLayout>